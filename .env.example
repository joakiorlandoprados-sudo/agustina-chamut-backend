# Server
PORT=3000

# Database (Neon Postgres)
# DATABASE_URL: conexión pooled (PgBouncer) — la usan la app y el cliente Prisma en runtime.
# DIRECT_URL:   conexión directa (sin pooler) — la usa Prisma para `migrate` y `db push`.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require&channel_binding=require"

# Auth
# JWT_SECRET: clave para firmar los tokens del panel admin. Generá una con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace-me-with-a-64-byte-random-hex-string"

# Email (Resend)
# RESEND_API_KEY: API key de Resend (https://resend.com/api-keys).
#   En sandbox (`onboarding@resend.dev` como FROM_EMAIL) los emails solo
#   salen a la dirección dueña de la API key. Para llegar a clientes reales
#   hay que verificar un dominio en Resend.
RESEND_API_KEY="re_replace_me"
# FROM_EMAIL: remitente. En producción debería ser un dominio verificado en
# Resend (ej. reservas@agustinachamut.com). En dev podés usar
# onboarding@resend.dev para probar sin configurar dominio.
FROM_EMAIL="onboarding@resend.dev"
# ADMIN_EMAIL: a dónde le llegan las notificaciones de reservas nuevas.
ADMIN_EMAIL="agustina@example.com"
# PUBLIC_URL: base del frontend. Se usa para armar el link de cancelación
# que va en el email al cliente. En prod apuntá a la URL de Vercel.
PUBLIC_URL="http://localhost:4200"
# WHATSAPP_NUMBER: número del negocio con código de país, sin '+'. Aparece
# como link en el email al cliente. Opcional: si no se define, no se muestra.
WHATSAPP_NUMBER="34604347114"
